PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/curalink

# Set to 1 for localhost preview without Docker / local Mongo (downloads binary on first run)
USE_MEMORY_DB=0
# Comma-separated for local + Vercel, e.g. http://localhost:5173,https://curalink-id6x.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Open-source LLM via Ollama
# Local: OLLAMA_URL=http://127.0.0.1:11434 (no key)
# Cloud: https://docs.ollama.com/api/authentication — set OLLAMA_API_KEY and use:
#   OLLAMA_URL=https://ollama.com
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# Optional — Ollama Cloud / API key (never commit real keys)
# OLLAMA_API_KEY=

# Optional: NCBI E-utilities identity (recommended — higher rate limits)
NCBI_EMAIL=your_email@example.com
NCBI_API_KEY=
